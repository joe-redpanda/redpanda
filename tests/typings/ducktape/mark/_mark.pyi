class Env(Mark):
    injected_args: Incomplete
    should_ignore: Incomplete
    def __init__(self, **kwargs) -> None: ...
    @property
    def name(self): ...
    def apply(self, seed_context, context_list): ...
    def __eq__(self, other): ...

PARAMETRIZED: Incomplete
MATRIX: Incomplete
DEFAULTS: Incomplete
IGNORE: Incomplete
OK_TO_FAIL: Incomplete
ENV: Incomplete

def parametrized(f): ...
def ignored(f): ...
def oked_to_fail(f): ...
def is_env(f): ...
def cartesian_product_dict(d): ...
def matrix(**kwargs: Any) -> Callable[[_F], _F]: ...
def defaults(**kwargs): ...
def parametrize(**kwargs): ...
def ignore(*args, **kwargs): ...
def ok_to_fail(*args, **kwargs): ...
def env(**kwargs): ...
