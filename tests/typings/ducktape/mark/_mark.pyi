from _typeshed import Incomplete
from ducktape.errors import DucktapeError as DucktapeError
from typing import Callable, TypeVar

from rptest.services.cluster import Any

_F = TypeVar("_F", bound=Callable[..., object])

class Mark:
    @staticmethod
    def mark(fun, mark) -> None: ...
    @staticmethod
    def marked(f, mark): ...
    @staticmethod
    def clear_marks(f) -> None: ...
    @property
    def name(self): ...
    def apply(self, seed_context, context_list) -> None: ...
    def __eq__(self, other): ...

class Ignore(Mark):
    injected_args: Incomplete
    def __init__(self, **kwargs) -> None: ...
    @property
    def name(self): ...
    def apply(self, seed_context, context_list): ...
    def __eq__(self, other): ...

class IgnoreAll(Ignore):
    injected_args: Incomplete
    def __init__(self) -> None: ...

class OkToFail(Mark):
    injected_args: Incomplete
    def __init__(self) -> None: ...
    @property
    def name(self): ...
    def apply(self, seed_context, context_list): ...

class Matrix(Mark):
    injected_args: Incomplete
    def __init__(self, **kwargs) -> None: ...
    @property
    def name(self): ...
    def apply(self, seed_context, context_list): ...
    def __eq__(self, other): ...

class Defaults(Mark):
    injected_args: Incomplete
    def __init__(self, **kwargs) -> None: ...
    @property
    def name(self): ...
    def apply(self, seed_context, context_list): ...
    def __eq__(self, other): ...

class Parametrize(Mark):
